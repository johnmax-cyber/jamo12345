rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Is the user authenticated?
    function isSignedIn() {
      return request.auth != null;
    }

    // Is the authenticated user an admin?
    // Boostrapped: johnmax4354@gmail.com is configured as an admin. We also allow checks for verified emails.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "johnmax4354@gmail.com" ||
        request.auth.token.email == "staff@susanscompany.com"
      );
    }

    // Valid unique ID constraint (alphanumeric, dashes, underscores)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Data helpers
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Product Catalog Protection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(productId);
    }

    // Diagnostic Connection Test Block
    match /test/{testId} {
      allow read: if true;
    }

    // Contact Messages Rules
    match /messages/{messageId} {
      // Users can submit inquiries
      allow create: if isValidId(messageId)
        && incoming().id == messageId
        && incoming().name is string && incoming().name.size() <= 200
        && incoming().phone is string && incoming().phone.size() <= 50
        && incoming().interest is string && incoming().interest.size() <= 100
        && incoming().message is string && incoming().message.size() <= 5000;
        
      // Only admins can view, update or prune messages
      allow read, update, delete: if isAdmin() && isValidId(messageId);
    }

    // Orders Rules
    match /orders/{orderId} {
      // Anyone can checkout/create their showroom order
      allow create: if isValidId(orderId)
        && incoming().id == orderId
        && incoming().customerName is string && incoming().customerName.size() <= 200
        && incoming().customerPhone is string && incoming().customerPhone.size() <= 50
        && incoming().totalAmount is number && incoming().totalAmount > 0
        && incoming().status == "pending"
        && incoming().deliveryLocation is string && incoming().deliveryLocation.size() <= 150
        && incoming().paymentMethod is string && incoming().paymentMethod.size() <= 50;
        
      // Only admins can modify, view list, or fulfill orders
      allow read, update, delete: if isAdmin() && isValidId(orderId);
    }
  }
}
